# Environment variables template. Copy this file to .env and fill in your values.
# The real .env is NOT committed to git (see .gitignore). This .example can be committed.

# Base URL of your Jira Cloud, WITHOUT a trailing slash.
JIRA_BASE_URL=https://your-domain.atlassian.net

# The email you log in to Atlassian with.
JIRA_EMAIL=you@example.com

# API token: id.atlassian.com -> Security -> Create API token.
JIRA_API_TOKEN=your_api_token_here

# Jira project key (ours is AIQA).
JIRA_PROJECT_KEY=AIQA

# Public SauceDemo test credentials (not secret, kept in .env so tests don't hardcode them).
SAUCE_USER=standard_user
SAUCE_PASSWORD=secret_sauce
